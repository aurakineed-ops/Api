<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <nav class="navbar navbar-expand-lg glass-card mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">🔮 OSINT HUB</a>
                <div class="ms-auto">
                    <span class="text-white me-3">Welcome, <%= user.username %></span>
                    <a href="/logout" class="btn btn-sm btn-danger">Logout</a>
                </div>
            </div>
        </nav>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="glass-card p-3 text-center">
                    <h3>📊 Total Hits</h3>
                    <h2><%= totalHits %></h2>
                </div>
            </div>
            <div class="col-md-6">
                <div class="glass-card p-3 text-center">
                    <h3>🔑 Active Keys</h3>
                    <h2><%= active %></h2>
                </div>
            </div>
        </div>

        <div class="glass-card p-4 mb-4">
            <h3>🔑 Generate API Key</h3>
            <form method="POST" action="/admin/generate-key">
                <div class="row">
                    <div class="col-md-4"><input type="text" name="name" placeholder="Key Name" class="form-control" required></div>
                    <div class="col-md-4"><input type="text" name="customer_name" placeholder="Customer Name" class="form-control"></div>
                    <div class="col-md-4"><input type="text" name="app_name" placeholder="App Name" class="form-control"></div>
                    <div class="col-md-3 mt-2">
                        <select name="expiry" class="form-control">
                            <option value="">No Expiry</option>
                            <option value="7d">7 Days</option>
                            <option value="30d">30 Days</option>
                        </select>
                    </div>
                    <div class="col-md-2 mt-2"><input type="number" name="rate_limit_per_day" placeholder="Daily" value="100" class="form-control"></div>
                    <div class="col-md-2 mt-2"><input type="number" name="rate_limit_per_hour" placeholder="Hourly" value="20" class="form-control"></div>
                    <div class="col-md-2 mt-2"><input type="number" name="rate_limit_per_minute" placeholder="Minute" value="5" class="form-control"></div>
                    <div class="col-md-3 mt-2"><input type="number" name="max_total_hits" placeholder="Max Total Hits (0=unlimited)" value="0" class="form-control"></div>
                    <div class="col-md-4 mt-2">
                        <select name="allowed_apis" class="form-control">
                            <option value="all">All APIs</option>
                            <option value="telegram">Telegram Only</option>
                            <option value="email_info">Email Only</option>
                        </select>
                    </div>
                    <div class="col-md-3 mt-2"><input type="text" name="custom_key" placeholder="Custom Key (optional)" class="form-control"></div>
                    <div class="col-md-2 mt-2"><input type="text" name="webhook_url" placeholder="Webhook URL" class="form-control"></div>
                    <div class="col-12 mt-3">
                        <label><input type="checkbox" name="unlimited_hits" value="true"> Unlimited Hits</label>
                        <label class="ms-3"><input type="checkbox" name="enable_custom" value="true"> Use Custom Key</label>
                    </div>
                    <div class="col-12 mt-3"><button type="submit" class="btn btn-primary">Generate Key</button></div>
                </div>
            </form>
        </div>

        <div class="glass-card p-4">
            <h3>📋 Existing API Keys</h3>
            <div class="table-responsive">
                <table>
                    <thead><tr><th>API Key</th><th>Name</th><th>Hits</th><th>Status</th><th>Expires</th><th>Actions</th></tr></thead>
                    <tbody>
                        <% keys.forEach(k => { %>
                        <tr>
                            <td><code><%= k.key %></code></td>
                            <td><%= k.name %></td>
                            <td><%= k.hits %></td>
                            <td><span class="badge bg-<%= k.status === 'active' ? 'success' : 'danger' %>"><%= k.status %></span></td>
                            <td><%= k.expires_at ? new Date(k.expires_at).toLocaleDateString() : 'Never' %></td>
                            <td>
                                <form method="POST" action="/admin/toggle-status" style="display:inline">
                                    <input type="hidden" name="id" value="<%= k.id %>">
                                    <input type="hidden" name="status" value="<%= k.status %>">
                                    <button class="btn btn-sm btn-warning"><%= k.status === 'active' ? 'Disable' : 'Enable' %></button>
                                </form>
                                <form method="POST" action="/admin/delete-key" style="display:inline">
                                    <input type="hidden" name="id" value="<%= k.id %>">
                                    <button class="btn btn-sm btn-danger" onclick="return confirm('Delete?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
