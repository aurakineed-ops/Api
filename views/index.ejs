<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSINT API Hub | @bmw_aura5</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg glass-card mb-4">
        <div class="container">
            <a class="navbar-brand text-white fw-bold" href="/">🔮 OSINT HUB</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link text-white" href="/endpoints">📡 Endpoints</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/docs">📚 Docs</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/portal">👤 Portal</a></li>
                    <% if (user) { %>
                        <li class="nav-item"><a class="nav-link text-white" href="/admin/dashboard">👑 Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link text-white" href="/logout">🚪 Logout</a></li>
                    <% } else { %>
                        <li class="nav-item"><a class="nav-link text-white" href="/login">🔐 Login</a></li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container text-center mt-5">
        <div class="animate-float">
            <h1 class="display-1 fw-bold welcome-text">WELCOME TO ERA OF SAHIL</h1>
            <p class="lead text-white-50 mt-3">Advanced OSINT API Hub | Rate Limited | Analytics | 24/7 Uptime</p>
        </div>

        <div class="row mt-5 g-4">
            <div class="col-md-4">
                <div class="glass-card p-4">
                    <div class="display-4">🔌</div>
                    <h3><%= totalApis %>+ APIs</h3>
                    <p class="text-white-50">Active endpoints ready to use</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card p-4">
                    <div class="display-4">🔑</div>
                    <h3><%= totalKeys %> Keys</h3>
                    <p class="text-white-50">API keys generated</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-card p-4">
                    <div class="display-4">📊</div>
                    <h3><%= totalHits %> Hits</h3>
                    <p class="text-white-50">Total API requests served</p>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <div class="glass-card p-4 d-inline-block">
                <code class="text-white">https://your-domain.onrender.com/api/v1/telegram?key=YOUR_KEY&id=8489944328</code>
                <div class="mt-3">
                    <a href="/login" class="btn btn-primary px-4 py-2 me-2">🔑 Admin Login</a>
                    <a href="/portal" class="btn btn-outline-info px-4 py-2">👤 Customer Portal</a>
                </div>
            </div>
        </div>

        <footer class="mt-5 text-white-50 small">
            <p>Owner: <strong>@bmw_aura5</strong> | Channel: <strong>@OSINT_ERA1</strong></p>
            <p>© 2025 OSINT API Hub | Powerful & Secure</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
