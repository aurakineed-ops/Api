<!DOCTYPE html>
<html>
<head>
    <title>API Endpoints</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg glass-card mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🔮 OSINT HUB</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/docs">Docs</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container">
        <h1 class="mb-4">📡 Available API Endpoints</h1>
        <div class="row">
            <% apis.forEach(api => { 
                let params = {};
                try { params = JSON.parse(api.required_params || '{}'); } catch(e) {}
                let paramName = Object.keys(params)[0] || 'param';
            %>
            <div class="col-md-6 mb-3">
                <div class="glass-card p-3">
                    <h4><%= api.display_name %></h4>
                    <p><%= api.description || 'No description' %></p>
                    <code class="d-block bg-dark p-2 rounded">
                        GET <%= baseUrl %><%= api.endpoint %>?key=YOUR_API_KEY&<%= paramName %>=<%= params[paramName] || 'value' %>
                    </code>
                    <button class="btn btn-sm btn-primary mt-2" onclick="copyToClipboard('<%= baseUrl %><%= api.endpoint %>?key=YOUR_API_KEY&<%= paramName %>=<%= params[paramName] || 'value' %>')">📋 Copy</button>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <script>
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
            alert('Copied!');
        }
    </script>
</body>
</html>
