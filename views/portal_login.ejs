<!DOCTYPE html>
<html>
<head>
    <title>Customer Portal Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex align-items-center" style="height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-4">
                <div class="glass-card p-4">
                    <h2 class="text-center">👤 Customer Portal</h2>
                    <% if (error) { %><div class="alert alert-danger">Invalid credentials</div><% } %>
                    <form method="POST" action="/portal/login">
                        <input type="email" name="email" class="form-control mb-3" placeholder="Email" required>
                        <input type="password" name="password" class="form-control mb-3" placeholder="Password" required>
                        <button type="submit" class="btn btn-primary w-100">Login</button>
                    </form>
                    <hr>
                    <small class="text-white-50">Contact @bmw_aura5 for portal access</small>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
